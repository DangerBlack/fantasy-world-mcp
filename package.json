{
  "name": "dnd-world-evolution",
  "version": "1.0.0",
  "description": "MCP server for procedural fantasy world evolution simulation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postbuild": "node fix-imports.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npm run build && node dist/test.js",
    "tasks": "node scripts/list-tasks.js",
    "task:transition": "node scripts/transition.js",
    "task:complete": "node scripts/complete.js"
  },
  "keywords": ["mcp", "dnd", "world-generation", "procedural", "fantasy"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
